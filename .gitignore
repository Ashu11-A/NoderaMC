# OS
.DS_Store

# Nodera runtime artifacts (anchored to repo root — an unanchored `nodera/` would also
# match the `dev/nodera/` source package in every module and silently hide new source files).
/nodera/
/divergences/
/world-store/

# Third-party architecture-study clones (local reference only; not part of NoderaMC).
# Our own analysis lives in docs/Context/*.md and docs/Context/docs/** — those ARE committed.
docs/Context/MultiPaper/
docs/Context/folia/

# jqwik property-test database (runtime artifact)
.jqwik-database

# Local NeoForge dedicated-server install (created by scripts/setup-server.sh):
# downloaded NeoForge libraries, world saves, logs, the copied mod jar — never committed.
/run/

# Stray Minecraft/NeoForge runtime logs if a server is ever launched from the repo root.
/logs/
/latest.log
/debug.log
/crash-reports/
hs_err_pid*.log

# Local API-token / env files — MUST never be committed (contain ANTHROPIC_AUTH_TOKEN etc.)
claude_code_zai_env.sh
/a
*.env
.env

# Rust build output (cargo workspace under rust/, Task 27).
/rust/target/

# Local agent/plugin settings (per-machine, not project config).
/.claude/
