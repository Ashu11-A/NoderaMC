{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nodera",
  "version": "0.1.0",
  "identifier": "dev.nodera.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ui run dev",
    "beforeBuildCommand": "npm --prefix ui run build"
  },
  "app": {
    "windows": [
      {
        "title": "Nodera",
        "width": 900,
        "height": 600,
        "minWidth": 640,
        "minHeight": 420,
        "resizable": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "tooltip": "Nodera"
    }
  },
  "plugins": {
    "autostart": {
      "args": []
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/nodera-headless": "resources/nodera-headless"
    }
  }
}
